PORT=3000
DB_PATH=./orders.db

# Для Яндекс.Почты используйте пароль приложения, а не обычный пароль от почты.
MAIL_ENABLED=true

# Recommended on Railway: Unisender sends email over HTTPS/443.
UNISENDER_API_KEY=your-unisender-api-key
UNISENDER_LIST_ID=123
UNISENDER_SENDER_EMAIL=your-verified-sender@example.com
UNISENDER_SENDER_NAME=Arbolit
ADMIN_EMAIL=manager@example.com

# Optional fallback: Brevo API also works over HTTPS/443.
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=Arbolit

# SMTP fallback. Railway may timeout on outbound SMTP ports.
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_TLS_SERVERNAME=smtp.yandex.ru
EMAIL_USER=your-mail@yandex.ru
EMAIL_PASS=your-app-password
